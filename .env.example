# --- Upstash Redis (view counter) ---
# Sign up at https://upstash.com (free) -> create Redis DB -> copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Google AdSense ---
# After approval, paste your publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX).
# Leave blank during development; AdSlot components no-op when empty.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Site URL (used by sitemap + Open Graph) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
